# ===================================================
# SEO×GEO 統合プラットフォーム 環境変数
# ===================================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env

# --- Database (Supabase PostgreSQL) ---
# Transaction mode (pooler port 6543) - アプリ用
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432) - マイグレーション用
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Google OAuth (Search Console連携) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- DataForSEO (順位取得API) ---
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# --- AI API Keys (GEOチェック用) ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GEMINI_API_KEY=""
PERPLEXITY_API_KEY=""

# --- Pay.jp (決済) ---
PAYJP_PUBLIC_KEY=""
PAYJP_SECRET_KEY=""
PAYJP_WEBHOOK_SECRET=""
PAYJP_PLAN_STARTER=""
PAYJP_PLAN_BUSINESS=""
PAYJP_PLAN_AGENCY=""

# --- Resend (メール通知) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@seogeo.jp"

# --- Cron (定期実行の認証) ---
CRON_SECRET=""

# --- Encryption (トークン暗号化) ---
ENCRYPTION_KEY=""

# --- Redis (ジョブキュー - BullMQ) ---
REDIS_URL="redis://localhost:6379"
